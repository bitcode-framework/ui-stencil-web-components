    "build:demo": "node src/demo/build-demo.js",
    "start": "stencil build --dev --watch --serve",
    "demo": "node scripts/kill-demo.js && stencil build && node src/demo/build-demo.js && npx -y http-server www -p 3333 -c-1 --cors -o /demo/",
