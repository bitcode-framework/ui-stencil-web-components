package main

import (
	"log"
	"net/http"
)

func main() {
	mux := http.NewServeMux()
{{range .Models}}
	// {{pascal .Name}} routes
	mux.HandleFunc("GET /{{lower .Name}}", list{{pascal .Name}}Handler)
	mux.HandleFunc("POST /{{lower .Name}}", create{{pascal .Name}}Handler)
	mux.HandleFunc("GET /{{lower .Name}}/{id}", get{{pascal .Name}}Handler)
	mux.HandleFunc("PUT /{{lower .Name}}/{id}", update{{pascal .Name}}Handler)
	mux.HandleFunc("DELETE /{{lower .Name}}/{id}", delete{{pascal .Name}}Handler)
{{end}}
	log.Println("Server starting on :3000")
	log.Fatal(http.ListenAndServe(":3000", mux))
}
